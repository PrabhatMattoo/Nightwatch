# apps/api/.env  — loaded by the API (run from apps/api).
# Copy to apps/api/.env and fill OPENAI_API_KEY.

# LLM provider (both adapters compiled in; pick one)
LLM_PROVIDER=openai                          # anthropic | openai

# OpenRouter (OpenAI-compatible) — used when LLM_PROVIDER=openai
OPENAI_API_KEY=                              # <- your OpenRouter key (sk-or-...)
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=openai/gpt-oss-120b:free

# Anthropic native — used when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Durable state: one SQLite file (the API's single system of record, D1). Its
# parent directory is created on boot if missing. No Redis, no Postgres (D2): the
# dispatcher and event bus are in-process.
NIGHTWATCH_DB_PATH=./data/nightwatch.db

GITHUB_TOKEN=                                # optional — get_recent_commits
PORT=3000

# Investigation concurrency cap and bounded in-memory backlog (overflow drops;
# the alert re-fires). Defaults are 5 and 100.
# INVESTIGATION_CONCURRENCY=5
# INVESTIGATION_QUEUE_MAX=100

# Single-admin auth seam (Phase 6). The login wall lands in Phase 7; until then
# the gate passes through. Set to "false" to enforce the gate early (every
# mutating route then 401s, since no login flow mints the session cookie yet).
NIGHTWATCH_DISABLE_AUTH=true
