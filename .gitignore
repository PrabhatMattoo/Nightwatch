# Dependencies
node_modules/

# Environment variables
.env
.env.local
.env.production

# Build output
dist/

# SQLite database files (runner local storage)
*.db
*.db-shm
*.db-wal

# Runner stable identity (generated per host at first start)
runner-id

# Claude Code — personal/generated only; settings.json, hooks/, rules/, agents/ are committed
.claude/settings.local.json
.claude/worktrees/
.claude/logs/

# Fetched skill content — regenerable from skills-lock.json (committed)
.claude/skills/

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# Local doc/reference dumps used while designing — not source
mantinedocs.txt
claudeapidocs.txt

# Local work tracking — issues stay untracked
issues

# Per-feature PRDs — local working docs, not published
.claude/*-prd.md
