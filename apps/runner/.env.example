# apps/runner/.env  — loaded by the runner (run from apps/runner).
# Copy to apps/runner/.env. No secrets needed for the local smoke test.

NIGHTWATCH_TOKEN=inst_local                  # must match a token in the Installation table
WS_URL=ws://localhost:3000/clients/connect
NIGHTWATCH_DB_PATH=./data/history.db         # local path (default /var/nightwatch needs root)
REMEDIATION_ENABLED=false                    # true enables write tools (Phase 5)
# HOST_PROC=/host/proc                       # set when running in container (default: /proc)
