# apps/api/.env  — loaded by the API and by Prisma (run from apps/api).
# Copy to apps/api/.env and fill OPENAI_API_KEY.

# LLM provider (both adapters compiled in; pick one)
LLM_PROVIDER=openai                          # anthropic | openai

# OpenRouter (OpenAI-compatible) — used when LLM_PROVIDER=openai
OPENAI_API_KEY=                              # <- your OpenRouter key (sk-or-...)
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=openai/gpt-oss-120b:free

# Anthropic native — used when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Backing stores (values match docker-compose.dev.yaml; ports shifted to avoid
# clashing with Clipper's own Postgres 5432 / Redis 6379).
DATABASE_URL=postgresql://nightwatch:nightwatch@localhost:5433/nightwatch
REDIS_URL=redis://localhost:6380

GITHUB_TOKEN=                                # optional — get_recent_commits
PORT=3000
