{
  "name": "nightwatch",
  "version": "2.5.1",
  "private": true,
  "engines": {
    "node": ">=20",
    "pnpm": ">=11"
  },
  "packageManager": "pnpm@11.5.1",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "dev": "pnpm --filter './apps/**' --parallel dev",
    "dev:infra": "docker compose -f docker-compose.dev.yaml up -d"
  },
  "devDependencies": {
    "typescript": "6.0.3",
    "prettier": "3.8.3"
  }
}
