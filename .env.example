# LLM provider (both adapters always available; select at runtime)
LLM_PROVIDER=openai                          # anthropic | openai

# Anthropic - native (prod)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI-compatible - OpenRouter (also OpenAI, Groq, etc. via baseURL)
OPENAI_API_KEY=sk-or-...                      # OpenRouter key
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=openai/gpt-oss-120b:free

# Platform (api)
DATABASE_URL=postgresql://nightwatch:nightwatch@localhost:5432/nightwatch
REDIS_URL=redis://localhost:6379
GITHUB_TOKEN=                                 # optional - get_recent_commits (platform-side)
PORT=3000

# Runner
NIGHTWATCH_TOKEN=inst_local                   # any string locally; becomes installationId
WS_URL=ws://localhost:3000/clients/connect
NIGHTWATCH_DB_PATH=./data/history.db
REMEDIATION_ENABLED=false                     # true to allow write commands (Phase 5)

# OpenRouter :free limits - 50 req/day (<$10 credits) or 1000/day (>=$10); 20 req/min.
# One investigation can use up to ~24 LLM calls; consider adding $10 before heavy testing.
