generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String  @id @default(cuid())
  email     String  @unique
  name      String?
  createdAt DateTime @default(now())
  tokens    Token[]
}

model Token {
  id        String   @id @default(cuid())
  token     String   @unique @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  hostname  String?
  createdAt DateTime @default(now())
}

// Global agent config: one row (id "global"). Seeded from env on first write;
// the API stores user edits here. apiKeyEncrypted is AES-256-GCM encrypted with
// SECRET_KEY and never returned to the console; the plaintext is never stored.
model Config {
  id               String   @id @default("global")
  provider         String   @default("anthropic")
  model            String   @default("claude-sonnet-4-6")
  thinking         String   @default("adaptive")
  maxOutputTokens  Int      @default(32000)
  maxRetries       Int      @default(2)
  requestTimeoutMs Int      @default(120000)
  maxToolCalls     Int      @default(24)
  hardTimeoutMs    Int      @default(300000)
  toolTimeoutMs    Int      @default(15000)
  // Provider endpoint config (issue 015)
  baseUrl          String?
  apiKeyEncrypted  String?
  promptCaching    Boolean  @default(true)
  reasoningEffort  String?
  updatedAt        DateTime @updatedAt
}
